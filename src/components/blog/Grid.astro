---
import Item from '~/components/blog/GridItem.astro';
import type { Post } from '~/types';

export interface Props {
  posts: Array<Post>;
}

const { posts } = Astro.props;

// Assign card variants in Avision masonry pattern:
// First post = large featured card, then alternate small variants
const getVariant = (index: number): 'large' | 'small' | 'background' => {
  if (index === 0) return 'large';
  if (index % 3 === 0) return 'background';
  return 'small';
};
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 -mb-6">
  {
    posts.map((post, index) => (
      <div class:list={[index === 0 ? 'md:col-span-2 lg:col-span-2 md:row-span-2' : '']}>
        <Item post={post} variant={getVariant(index)} />
      </div>
    ))
  }
</div>
