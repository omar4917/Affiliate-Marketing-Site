---
import type { ImageMetadata } from 'astro';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';

interface ComparisonItem {
  title: string;
  image?: string | ImageMetadata;
  rating?: number;
  verdict?: string;
  features?: string[];
  price?: string;
  affiliateUrl: string;
  ctaText?: string;
  isWinner?: boolean;
  winnerLabel?: string;
}

interface Props {
  items: ComparisonItem[];
  maxRating?: number;
}

const { items = [], maxRating = 5 } = Astro.props;
---

<div
  class="my-8 overflow-hidden rounded-2xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 shadow-md"
>
  {/* Desktop Table View (hidden on small screens) */}
  <div class="hidden md:block overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-gray-50/70 dark:bg-slate-800/40 border-b border-gray-200 dark:border-slate-800">
          <th class="py-4 px-6 text-sm font-bold text-heading">Product</th>
          <th class="py-4 px-6 text-sm font-bold text-heading text-center">Rating</th>
          <th class="py-4 px-6 text-sm font-bold text-heading">Key Features</th>
          <th class="py-4 px-6 text-sm font-bold text-heading">Verdict</th>
          <th class="py-4 px-6 text-sm font-bold text-heading text-center">Price</th>
          <th class="py-4 px-6 text-sm font-bold text-heading text-right">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-slate-800">
        {
          items.map((item) => (
            <tr
              class={`transition-colors duration-150 hover:bg-gray-50/40 dark:hover:bg-slate-850/20 ${item.isWinner ? 'bg-blue-50/20 dark:bg-blue-950/10' : ''}`}
            >
              {/* Product Image & Name */}
              <td class="py-5 px-6 font-medium text-heading">
                <div class="flex items-center gap-4">
                  {item.image && (
                    <div class="w-16 h-16 rounded-lg bg-gray-50 dark:bg-slate-800 flex-shrink-0 flex items-center justify-center p-1 border border-gray-100 dark:border-slate-700">
                      <Image
                        src={item.image}
                        class="object-contain max-h-full"
                        width={60}
                        height={60}
                        alt={item.title}
                      />
                    </div>
                  )}
                  <div>
                    <div class="font-bold font-heading text-base text-page">{item.title}</div>
                    {item.isWinner && (
                      <span class="inline-flex items-center gap-1 mt-1 rounded bg-amber-500/10 text-amber-600 dark:text-amber-400 px-1.5 py-0.5 text-2xs font-extrabold uppercase tracking-wider">
                        <Icon name="tabler:award-filled" class="w-3.5 h-3.5" />
                        {item.winnerLabel || 'Top Pick'}
                      </span>
                    )}
                  </div>
                </div>
              </td>

              {/* Rating */}
              <td class="py-5 px-6 text-center">
                {item.rating !== undefined && (
                  <div class="inline-flex flex-col items-center">
                    <span class="text-base font-extrabold text-page leading-none">{item.rating.toFixed(1)}</span>
                    <div class="flex text-yellow-400 mt-1">
                      {Array.from({ length: maxRating }).map((_, i) => (
                        <Icon
                          name={i < Math.floor(item.rating || 0) ? 'tabler:star-filled' : 'tabler:star'}
                          class="w-3.5 h-3.5"
                        />
                      ))}
                    </div>
                  </div>
                )}
              </td>

              {/* Key Features */}
              <td class="py-5 px-6">
                {item.features && item.features.length > 0 ? (
                  <ul class="space-y-1 text-xs text-muted">
                    {item.features.slice(0, 3).map((feature) => (
                      <li class="flex items-center gap-1.5">
                        <Icon name="tabler:circle-check" class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0" />
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <span class="text-xs text-muted">—</span>
                )}
              </td>

              {/* Verdict */}
              <td class="py-5 px-6">
                <span class="text-xs font-semibold text-page block max-w-[150px] leading-relaxed">
                  {item.verdict || 'Highly Recommended'}
                </span>
              </td>

              {/* Price */}
              <td class="py-5 px-6 text-center">
                <span class="text-base font-extrabold text-page whitespace-nowrap">{item.price || 'N/A'}</span>
              </td>

              {/* Action Link */}
              <td class="py-5 px-6 text-right">
                <Button
                  variant={item.isWinner ? 'primary' : 'secondary'}
                  href={item.affiliateUrl}
                  target="_blank"
                  class="px-4 py-2 text-xs font-bold rounded-lg shadow-sm"
                  icon="tabler:external-link"
                >
                  {item.ctaText || 'Shop Now'}
                </Button>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  {/* Mobile List View (hidden on medium/large screens) */}
  <div class="block md:hidden divide-y divide-gray-100 dark:divide-slate-800">
    {
      items.map((item) => (
        <div class={`p-5 relative ${item.isWinner ? 'bg-blue-50/10 dark:bg-blue-950/5' : ''}`}>
          {item.isWinner && (
            <div class="absolute top-4 right-4 bg-amber-500 text-black px-2 py-0.5 rounded text-3xs font-extrabold uppercase tracking-wide flex items-center gap-1">
              <Icon name="tabler:award-filled" class="w-3 h-3" />
              {item.winnerLabel || 'Top Pick'}
            </div>
          )}

          <div class="flex items-start gap-4 mb-4">
            {item.image && (
              <div class="w-16 h-16 rounded-lg bg-gray-50 dark:bg-slate-800 flex-shrink-0 flex items-center justify-center p-1 border border-gray-100 dark:border-slate-700">
                <Image src={item.image} class="object-contain max-h-full" width={60} height={60} alt={item.title} />
              </div>
            )}
            <div>
              <h4 class="font-bold text-base text-page pr-16">{item.title}</h4>
              <div class="flex items-center gap-2 mt-1">
                {item.rating !== undefined && (
                  <div class="flex items-center gap-1 text-xs">
                    <span class="font-extrabold text-page">{item.rating.toFixed(1)}</span>
                    <div class="flex text-yellow-400">
                      <Icon name="tabler:star-filled" class="w-3 h-3" />
                    </div>
                  </div>
                )}
                {item.price && (
                  <span class="text-xs font-extrabold text-gray-500 dark:text-gray-400">• {item.price}</span>
                )}
              </div>
            </div>
          </div>

          {/* Verdict & Features */}
          <div class="space-y-3 mb-4">
            {item.verdict && (
              <div class="text-xs">
                <span class="font-bold text-page">Verdict: </span>
                <span class="text-muted">{item.verdict}</span>
              </div>
            )}
            {item.features && item.features.length > 0 && (
              <div class="grid grid-cols-1 gap-1 text-xs text-muted bg-gray-50/50 dark:bg-slate-800/30 p-2.5 rounded-lg">
                {item.features.slice(0, 3).map((feature) => (
                  <div class="flex items-center gap-1.5">
                    <Icon name="tabler:circle-check" class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0" />
                    <span>{feature}</span>
                  </div>
                ))}
              </div>
            )}
          </div>

          {/* Action button */}
          <Button
            variant={item.isWinner ? 'primary' : 'secondary'}
            href={item.affiliateUrl}
            target="_blank"
            class="w-full text-center py-2.5 text-xs font-bold rounded-lg shadow-sm"
            icon="tabler:external-link"
          >
            {item.ctaText || 'Shop Now'}
          </Button>
        </div>
      ))
    }
  </div>
</div>
