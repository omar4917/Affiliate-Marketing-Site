---
import type { ImageMetadata } from 'astro';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  image?: string | ImageMetadata;
  rating?: number;
  maxRating?: number;
  description?: string;
  pros?: string[];
  cons?: string[];
  specs?: Record<string, string>;
  price?: string;
  affiliateUrl: string;
  ctaText?: string;
  badge?: string;
  ribbonColor?: 'primary' | 'secondary' | 'accent' | 'success' | 'warning';
}

const {
  title,
  image,
  rating = 5,
  maxRating = 5,
  description,
  pros = [],
  cons = [],
  specs = {},
  price,
  affiliateUrl,
  ctaText = 'View Deal',
  badge,
  ribbonColor = 'primary',
} = Astro.props;

// Determine badge color classes
const badgeColors = {
  primary: 'bg-primary text-white',
  secondary: 'bg-secondary text-white',
  accent: 'bg-accent text-white',
  success: 'bg-emerald-600 text-white dark:bg-emerald-700',
  warning: 'bg-amber-500 text-black dark:text-white dark:bg-amber-600',
};

const badgeClass = badgeColors[ribbonColor] || badgeColors.primary;
---

<div
  class="relative overflow-hidden rounded-2xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 backdrop-blur-sm shadow-md hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row gap-6 p-6 md:p-8 my-8 group"
>
  {
    badge && (
      <div
        class={`absolute top-0 right-0 rounded-bl-xl px-4 py-1.5 text-xs font-bold uppercase tracking-wider ${badgeClass} z-10 shadow-sm`}
      >
        {badge}
      </div>
    )
  }

  {/* Image Container */}
  {
    image && (
      <div class="w-full md:w-1/3 flex-shrink-0 flex items-center justify-center bg-gray-50 dark:bg-slate-800/40 rounded-xl overflow-hidden min-h-[200px] md:min-h-0 relative">
        <Image
          src={image}
          class="max-h-[220px] object-contain transition-transform duration-500 group-hover:scale-105 p-4"
          width={300}
          height={220}
          alt={title}
        />
      </div>
    )
  }

  {/* Content Details */}
  <div class="flex-grow flex flex-col justify-between">
    <div>
      {/* Title & Rating */}
      <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
        <h3 class="text-xl md:text-2xl font-bold font-heading text-heading pr-12">
          {title}
        </h3>

        {
          rating !== undefined && (
            <div class="flex items-center gap-1 bg-yellow-50 dark:bg-yellow-950/30 border border-yellow-200 dark:border-yellow-900/50 px-2.5 py-1 rounded-lg">
              <span class="text-sm font-bold text-yellow-700 dark:text-yellow-400">{rating.toFixed(1)}</span>
              <div class="flex text-yellow-400">
                {Array.from({ length: maxRating }).map((_, i) => {
                  const isFull = i < Math.floor(rating);
                  const isHalf = !isFull && i < rating;
                  return (
                    <Icon
                      name={isFull ? 'tabler:star-filled' : isHalf ? 'tabler:star-half-filled' : 'tabler:star'}
                      class="w-4 h-4"
                    />
                  );
                })}
              </div>
            </div>
          )
        }
      </div>

      {/* Description */}
      {description && <p class="text-muted text-sm md:text-base mb-4 leading-relaxed">{description}</p>}

      {/* Specs (Optional) */}
      {
        Object.keys(specs).length > 0 && (
          <div class="grid grid-cols-2 gap-x-4 gap-y-1.5 mb-5 bg-gray-50/50 dark:bg-slate-800/20 p-3 rounded-lg text-xs">
            {Object.entries(specs).map(([key, value]) => (
              <div class="flex justify-between border-b border-gray-100 dark:border-slate-800/80 pb-1">
                <span class="font-medium text-muted">{key}:</span>
                <span class="font-semibold text-page text-right">{value}</span>
              </div>
            ))}
          </div>
        )
      }

      {/* Pros & Cons */}
      {
        (pros.length > 0 || cons.length > 0) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
            {pros.length > 0 && (
              <div class="space-y-2">
                <span class="text-xs font-bold text-emerald-600 dark:text-emerald-400 tracking-wider uppercase flex items-center gap-1.5">
                  <Icon name="tabler:circle-check" class="w-4.5 h-4.5 text-emerald-500" /> Pros
                </span>
                <ul class="space-y-1.5 text-xs text-muted">
                  {pros.map((pro) => (
                    <li class="flex items-start gap-1.5">
                      <span class="text-emerald-500 font-bold select-none">•</span>
                      <span>{pro}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {cons.length > 0 && (
              <div class="space-y-2">
                <span class="text-xs font-bold text-rose-600 dark:text-rose-400 tracking-wider uppercase flex items-center gap-1.5">
                  <Icon name="tabler:circle-x" class="w-4.5 h-4.5 text-rose-500" /> Cons
                </span>
                <ul class="space-y-1.5 text-xs text-muted">
                  {cons.map((con) => (
                    <li class="flex items-start gap-1.5">
                      <span class="text-rose-500 font-bold select-none">•</span>
                      <span>{con}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )
      }
    </div>

    {/* Price & CTA Action */}
    <div
      class="flex flex-wrap items-center justify-between gap-4 mt-6 pt-4 border-t border-gray-100 dark:border-slate-800/80"
    >
      {
        price && (
          <div class="flex flex-col">
            <span class="text-xs text-muted font-medium uppercase tracking-wider">Best Price</span>
            <span class="text-2xl font-extrabold text-page">{price}</span>
          </div>
        )
      }

      <div class="flex-grow md:flex-grow-0">
        <Button
          variant="primary"
          href={affiliateUrl}
          target="_blank"
          class="w-full md:w-auto shadow-lg hover:shadow-primary/30 transition-all duration-300 font-semibold"
          icon="tabler:arrow-up-right"
        >
          {ctaText}
        </Button>
      </div>
    </div>
  </div>
</div>
