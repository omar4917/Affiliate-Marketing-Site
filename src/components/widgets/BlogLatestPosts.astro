---
import { APP_BLOG } from 'astrowind:config';

import Grid from '~/components/blog/Grid.astro';

import { getBlogPermalink } from '~/utils/permalinks';
import { findLatestPosts } from '~/utils/blog';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Widget } from '~/types';
import Button from '~/components/ui/Button.astro';

export interface Props extends Widget {
  title?: string;
  linkText?: string;
  linkUrl?: string | URL;
  information?: string;
  count?: number;
}

const {
  title = await Astro.slots.render('title'),
  linkText = 'View all posts',
  linkUrl = getBlogPermalink(),
  information = await Astro.slots.render('information'),
  count = 4,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const posts = APP_BLOG.isEnabled ? await findLatestPosts({ count }) : [];
---

{
  APP_BLOG.isEnabled ? (
    <WidgetWrapper id={id} isDark={isDark} containerClass={classes?.container as string} bg={bg}>
      {/* Avision-style section panel header */}
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
        {title && (
          <div>
            <h2
              class="avision-title text-2xl font-bold tracking-tight sm:text-3xl font-heading dark:text-slate-200 mb-0"
              set:html={title}
            />
          </div>
        )}
        <div class="flex items-center gap-6">
          {information && <p class="text-muted dark:text-slate-400 text-sm max-w-md" set:html={information} />}
          {APP_BLOG.list.isEnabled && linkText && linkUrl && (
            <Button variant="link" href={linkUrl}>
              {linkText} »
            </Button>
          )}
        </div>
      </div>

      <Grid posts={posts} />
    </WidgetWrapper>
  ) : (
    <Fragment />
  )
}
