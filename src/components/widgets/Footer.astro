---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '' } = Astro.props;
---

<footer class="relative not-prose bg-[#1f1f1f] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 py-12 md:py-16">
      <!-- Left side: Logo + Links + Social + Copyright (spans 9 cols) -->
      <div
        class="lg:col-span-9 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <!-- Footer Logo -->
        <div class="mb-6">
          <a
            class="inline-block text-2xl font-heading font-bold uppercase tracking-wider text-white hover:text-primary transition duration-200"
            href={getHomePermalink()}
          >
            {SITE?.name}
          </a>
        </div>

        <!-- Footer Link Columns -->
        {
          links.length > 0 && (
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 mb-8">
              {links.map(({ title, links: subLinks }) => (
                <div>
                  <div class="text-white/90 font-heading font-bold text-sm uppercase tracking-wider mb-3">{title}</div>
                  {subLinks && Array.isArray(subLinks) && subLinks.length > 0 && (
                    <ul class="text-sm space-y-2">
                      {subLinks.map(({ text, href, ariaLabel }) => (
                        <li>
                          <a
                            class="text-white/50 hover:text-primary transition duration-200"
                            href={href}
                            aria-label={ariaLabel}
                          >
                            <Fragment set:html={text} />
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          )
        }

        <!-- Social Links -->
        {
          socialLinks?.length > 0 && (
            <ul class="flex gap-3 mb-6">
              {socialLinks.map(({ ariaLabel, href, icon }) => (
                <li>
                  <a
                    class="flex items-center justify-center w-9 h-9 rounded-full bg-white/10 text-white/60 hover:bg-primary hover:text-white transition duration-200"
                    aria-label={ariaLabel}
                    href={href}
                  >
                    {icon && <Icon name={icon} class="w-4 h-4" />}
                    {ariaLabel && <span class="sr-only">{ariaLabel}</span>}
                  </a>
                </li>
              ))}
            </ul>
          )
        }

        <!-- Copyright / Secondary Links -->
        <div class="flex flex-wrap items-center gap-3 text-xs text-white/30">
          {footNote && <Fragment set:html={footNote} />}
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? <span>·</span> : ''}
                <a class="hover:text-white/60 transition duration-150" href={href} set:html={text} />
              </>
            ))
          }
        </div>
      </div>

      <!-- Right side: Subscribe section (spans 3 cols) -->
      <div
        class="lg:col-span-3 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <div class="relative bg-primary/90 rounded-lg p-6 md:p-8">
          <div class="text-xl font-heading font-bold text-white mb-4">Subscribe</div>
          <form action="#" class="flex flex-col gap-3">
            <input
              type="email"
              class="w-full bg-white/20 backdrop-blur-sm border border-white/10 rounded-md px-4 py-3 text-sm text-white placeholder:text-white/50 focus:outline-none focus:ring-2 focus:ring-white/40 transition"
              placeholder="Your Email"
              required
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 bg-white text-primary font-heading font-bold text-sm uppercase tracking-wider rounded-md py-3 px-6 hover:bg-white/90 transition duration-200"
            >
              Subscribe
              <svg width="19" height="13" viewBox="0 0 19 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polygon
                  fill="currentColor"
                  points="12.475,0 11.061,0 17.081,6.021 0,6.021 0,7.021 17.038,7.021 11.06,13 12.474,13 18.974,6.5"
                ></polygon>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</footer>
