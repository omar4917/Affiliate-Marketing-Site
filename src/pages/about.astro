---
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Synchrove',
  description: 'Learn about Synchrove, our review standards, and how we help developers find the best cloud hosting and developer tools.',
};
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <Hero
    tagline="Our Mission"
    image={{
      src: 'https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&w=1200&q=80',
      alt: 'Developers collaborating on code',
    }}
  >
    <Fragment slot="title">
      Helping you choose the best <br />
      <span class="text-accent dark:text-blue-400">Developer & Cloud Hosting</span> tools
    </Fragment>

    <Fragment slot="subtitle">
      Synchrove was founded to cut through the marketing hype of modern cloud platforms. We test, benchmark, and review web hosting, developer resources, and SaaS products so you can launch faster, scale efficiently, and save money.
    </Fragment>
  </Hero>

  {/* Review Process / Core Values */}
  <Steps2
    title="Our Review Standards"
    subtitle="We believe in transparency, speed, and real-world testing. Here is how we evaluate developer products:"
    items={[
      {
        title: 'Real-world Benchmarking',
        description:
          'We do not just copy specification sheets. We deploy actual projects on Vercel, Netlify, Cloudflare Pages, and others to test raw build speeds, edge performance, and uptime.',
      },
      {
        title: 'No Bias, True Opinions',
        description:
          'While we use affiliate links to support our publishing costs, our reviews are 100% independent. If a hosting provider has high overage fees or slow deployment queues, we call it out.',
      },
      {
        title: 'Developer Focused',
        description:
          'Our reviews focus on developer experience (DX), Git integration flow, environment configurations, and documentation usability.',
      },
    ]}
  />

  {/* Features3 - Focus Areas */}
  <Features3
    title="What We Cover"
    subtitle="We analyze the core layers of modern web infrastructure to keep your projects fast and reliable."
    columns={3}
    items={[
      {
        title: 'Frontend Hosting',
        description: 'Detailed comparisons of Vercel, Netlify, Cloudflare Pages, and AWS Amplify.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'Developer Frameworks',
        description: 'Guides and optimizations for building static and SSR apps with Astro, Next.js, and SvelteKit.',
        icon: 'tabler:code',
      },
      {
        title: 'Serverless & Database',
        description: 'Evaluations of serverless compute, edge networks, and modern databases.',
        icon: 'tabler:database',
      },
    ]}
  />
</Layout>
