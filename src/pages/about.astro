---
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Synchrove',
  description:
    'Learn about Synchrove, our review standards, and how we help you find the best online tools and consumer products.',
};
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <Hero
    tagline="About Us"
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80',
      alt: 'Analyzing reviews and product charts',
    }}
  >
    <Fragment slot="title">
      Your trusted guide to finding the <br />
      <span class="text-accent dark:text-blue-400">Best Products & Tools</span>
    </Fragment>

    <Fragment slot="subtitle">
      Synchrove is an independent review and recommendation portal. Our mission is simple: we search the web, analyze
      specifications, compile real-user feedback, and write deep-dive comparisons on digital items, developer resources,
      and consumer products so you can buy with confidence.
    </Fragment>
  </Hero>

  {/* Review Process / Core Values */}
  <Steps2
    title="Why Trust Synchrove?"
    subtitle="We do the research so you don't have to. Here is our affiliate review philosophy:"
    items={[
      {
        title: 'Objective Research',
        description:
          'We evaluate products based on features, value for money, user feedback, and real-world utility, highlighting both the positives and negatives.',
      },
      {
        title: 'Affiliate Transparency',
        description:
          'We partner with top platforms (including Amazon and digital software providers). When you click our links and make a purchase, we earn a small commission at zero extra cost to you. This support keeps our reviews independent and free.',
      },
      {
        title: 'Up-to-Date Deals',
        description:
          'Prices and product versions change fast. We monitor our recommendation databases and update deal links instantly so you always get the best active offers.',
      },
    ]}
  />

  {/* Features3 - Focus Areas */}
  <Features3
    title="What We Review"
    subtitle="From digital software tools to physical products, we cover the essentials."
    columns={3}
    items={[
      {
        title: 'SaaS & Digital Software',
        description: 'Comparisons of design tools, website builders, templates, and productivity software.',
        icon: 'tabler:app-window',
      },
      {
        title: 'Developer Resources',
        description: 'Guides on frontend frameworks, code template structures, and web hosting platforms.',
        icon: 'tabler:code',
      },
      {
        title: 'Consumer Products',
        description:
          'Reviews and lists of hardware, gadgets, and popular everyday products from major stores like Amazon.',
        icon: 'tabler:shopping-cart',
      },
    ]}
  />
</Layout>
