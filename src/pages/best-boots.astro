---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ComparisonTable from '~/components/ui/ComparisonTable.astro';
import ProductReviewCard from '~/components/ui/ProductReviewCard.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getCollection } from 'astro:content';

const reviews = await getCollection('review', ({ data }) => {
  return data.category === 'boots';
});

// Sort reviews by rating descending (highest rating first)
const sortedReviews = reviews.sort((a, b) => (b.data.rating || 0) - (a.data.rating || 0));

const hostingProviders = sortedReviews.map((review) => ({
  title: review.data.title,
  image: review.data.image,
  rating: review.data.rating,
  verdict: review.data.verdict,
  features: review.data.features,
  price: review.data.price,
  affiliateUrl: review.data.affiliateUrl,
  ctaText: review.data.ctaText,
  isWinner: review.data.isWinner,
  winnerLabel: review.data.winnerLabel,
  ribbonColor: review.data.ribbonColor,
  description: review.data.description,
  specs: review.data.specs,
  pros: review.data.pros,
  cons: review.data.cons,
}));

const metadata = {
  title: 'Best Football Boots of 2026: On-Pitch Reviews & Comparison',
  description:
    'Looking for the best football boots in 2026? Read our detailed, on-pitch comparison of Nike, Adidas, and Puma boots to find the perfect match for your playstyle and surface.',
};
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <HeroText
    tagline="Football Boots Comparison"
    title="Best Football Boots for Players (2026)"
    subtitle="Choosing the right boots can make or break your performance and prevent injury. We analyzed and tested the leading football boots for all playstyles."
  />

  {/* Comparison Table Section */}
  <section class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-6">
      <h2 class="text-2xl font-bold font-heading text-heading">At a Glance: Top Football Boots Compared</h2>
      <p class="text-muted text-sm mt-1">
        Here is a quick breakdown of how these top elite-level football boots stack up in pricing, rating, and
        specifications.
      </p>
    </div>

    <ComparisonTable items={hostingProviders} />
  </section>

  {/* In-depth Review Cards */}
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-extrabold font-heading text-page">In-Depth Reviews</h2>
      <p class="text-muted mt-2 max-w-xl mx-auto">
        Read on for our detailed breakdown of each boot's control, speed, comfort, pros, and cons.
      </p>
    </div>

    {
      hostingProviders.map((provider) => (
        <ProductReviewCard
          title={provider.title}
          image={provider.image}
          rating={provider.rating}
          price={provider.price}
          badge={provider.winnerLabel}
          ribbonColor={provider.ribbonColor as 'primary' | 'secondary' | 'accent' | 'success' | 'warning'}
          description={provider.description}
          specs={provider.specs as unknown as Record<string, string>}
          pros={provider.pros}
          cons={provider.cons}
          affiliateUrl={provider.affiliateUrl}
          ctaText={provider.ctaText}
        />
      ))
    }
  </section>

  {/* Call To Action */}
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Find Your Boot',
        href: '/blog',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title"> Want to elevate your play on the pitch? </Fragment>
    <Fragment slot="subtitle">
      Check out our drills and tactics guides to take your training to the next level.
    </Fragment>
  </CallToAction>
</Layout>
