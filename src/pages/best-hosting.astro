---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ComparisonTable from '~/components/ui/ComparisonTable.astro';
import ProductReviewCard from '~/components/ui/ProductReviewCard.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Best Developer Hosting Platforms of 2026 - Affiliate Reviews',
  description: 'An in-depth review and comparison of the top hosting services for modern web developers.',
};

// Data for the Comparison Table
const hostingProviders = [
  {
    title: 'Vercel',
    image: 'https://images.unsplash.com/photo-1618477388954-7852f32655ec?auto=format&fit=crop&w=150&q=80',
    rating: 4.9,
    verdict: 'Best overall for Next.js & React frameworks. Seamless DX.',
    features: ['Instant Git deployments', 'Edge Middleware & Functions', 'Visual Editing support'],
    price: '$20 / mo',
    affiliateUrl: 'https://vercel.com',
    ctaText: 'Visit Vercel',
    isWinner: true,
    winnerLabel: 'Overall Winner',
  },
  {
    title: 'Netlify',
    image: 'https://images.unsplash.com/photo-1618477388954-7852f32655ec?auto=format&fit=crop&w=150&q=80',
    rating: 4.6,
    verdict: 'Excellent choice for JAMstack blogs and custom forms.',
    features: ['Built-in Form handling', 'Netlify Connect CMS integration', 'Split Testing / Analytics'],
    price: '$19 / mo',
    affiliateUrl: 'https://netlify.com',
    ctaText: 'Visit Netlify',
  },
  {
    title: 'Cloudflare Pages',
    image: 'https://images.unsplash.com/photo-1618477388954-7852f32655ec?auto=format&fit=crop&w=150&q=80',
    rating: 4.7,
    verdict: 'Best value for static sites with global edge network.',
    features: ['Unlimited free bandwidth', 'Cloudflare Workers support', 'Unrivaled DDoS protection'],
    price: 'Free / $0',
    affiliateUrl: 'https://pages.cloudflare.com',
    ctaText: 'Visit Cloudflare',
    isWinner: true,
    winnerLabel: 'Best Value',
  },
];
---

<Layout metadata={metadata}>
  {/* Hero Section */}
  <HeroText
    tagline="Developer Tools Comparison"
    title="Best Web Hosting Services for Developers (2026)"
    subtitle="Choosing the right platform can make or break your site's performance and SEO. We analyzed and tested the leading hosting options for frontend developers."
  />

  {/* Comparison Table Section */}
  <section class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-6">
      <h2 class="text-2xl font-bold font-heading text-heading">At a Glance: Top Web Hosts Compared</h2>
      <p class="text-muted text-sm mt-1">
        Here is a quick breakdown of how these top cloud hosting solutions stack up in pricing, rating, and key
        benefits.
      </p>
    </div>

    <ComparisonTable items={hostingProviders} />
  </section>

  {/* In-depth Review Cards */}
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-extrabold font-heading text-page">In-Depth Reviews</h2>
      <p class="text-muted mt-2 max-w-xl mx-auto">
        Read on for our detailed breakdown of each provider's developer experience, performance, pricing structures, and
        pros/cons.
      </p>
    </div>

    {/* Product 1: Vercel */}
    <ProductReviewCard
      title="Vercel Hosting Platform"
      image="https://images.unsplash.com/photo-1618477388954-7852f32655ec?auto=format&fit=crop&w=300&q=80"
      rating={4.9}
      price="$20 / month"
      badge="Overall Winner"
      ribbonColor="primary"
      description="Vercel is the ultimate frontend cloud platform, designed specifically to optimize build speed and performance for modern frameworks like Next.js, Nuxt, and Astro. It offers serverless deployment, global CDN, analytics, and collaborative preview comments out of the box."
      specs={{
        'Primary Framework': 'Next.js / React',
        'Bandwidth Limit': '1 TB (Pro)',
        'Edge Functions': 'Included',
        Analytics: 'Built-in Addon',
      }}
      pros={[
        'Industry-leading Developer Experience (DX) with Git integration',
        'Fast global edge network with instant cache invalidation',
        'Support for dynamic edge routing and serverless functions',
        'Automatic SEO optimization features (Image optimization, script tags)',
      ]}
      cons={[
        'Bandwidth overage fees can be expensive on high-traffic sites',
        'Pro plan is $20 per seat, which can add up for larger teams',
      ]}
      affiliateUrl="https://vercel.com"
      ctaText="Deploy on Vercel"
    />

    {/* Product 2: Netlify */}
    <ProductReviewCard
      title="Netlify Hosting Service"
      image="https://images.unsplash.com/photo-1618477388954-7852f32655ec?auto=format&fit=crop&w=300&q=80"
      rating={4.6}
      price="$19 / month"
      description="Netlify is a pioneer of the JAMstack movement. It provides developers with seamless Git-based build pipelines, serverless functions, form submission processing, split testing, and a highly customizable user dashboard. It's an excellent multi-framework hosting choice."
      specs={{
        'Primary Framework': 'Any SSG / Astro / Nuxt',
        'Bandwidth Limit': '1 TB (Pro)',
        'Form Submissions': '100 / mo (Free)',
        'Identity (Auth)': 'Up to 1k users (Free)',
      }}
      pros={[
        'Built-in forms and user authentication databases',
        'Split testing allows running A/B experiments natively at the CDN level',
        'Netlify Connect offers excellent headless database integrations',
      ]}
      cons={[
        'Deploy times can sometimes be slower compared to competitors',
        'Serverless execution limits are tighter on the free tier',
      ]}
      affiliateUrl="https://netlify.com"
      ctaText="Start Free with Netlify"
    />

    {/* Product 3: Cloudflare Pages */}
    <ProductReviewCard
      title="Cloudflare Pages"
      image="https://images.unsplash.com/photo-1618477388954-7852f32655ec?auto=format&fit=crop&w=300&q=80"
      rating={4.7}
      price="Free / $0"
      badge="Best Value"
      ribbonColor="success"
      description="Cloudflare Pages integrates directly with Git to build and host static websites. Powered by Cloudflare's massive global network spanning 300+ cities, it offers unrivaled speed, security, and uptime. The free plan is incredibly generous, offering unlimited bandwidth."
      specs={{
        'Primary Framework': 'Astro, Hugo, SvelteKit',
        'Bandwidth Limit': 'Unlimited Free',
        'Global Locations': '300+ Edge Nodes',
        'DDoS Protection': 'Enterprise Grade',
      }}
      pros={[
        'Absolutely unlimited free bandwidth and build minutes',
        'World-class DDoS security and web application firewall (WAF)',
        'Deep integration with Cloudflare Workers and KV databases',
      ]}
      cons={[
        'Web dashboard is geared towards network engineers, which can feel complex',
        'Build setup configuration has a steeper learning curve for beginners',
      ]}
      affiliateUrl="https://pages.cloudflare.com"
      ctaText="Host Free on Cloudflare"
    />
  </section>

  {/* Call To Action */}
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Build Your Site',
        href: '/blog',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title"> Want to build your own high-converting site? </Fragment>
    <Fragment slot="subtitle"> Check out our guides and templates to launch your developer blog in minutes. </Fragment>
  </CallToAction>
</Layout>
