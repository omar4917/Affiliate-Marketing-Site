---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Synchrove',
  description: 'Reach out to Synchrove with questions, suggestions, feedback, or partnership opportunities.',
};
---

<Layout metadata={metadata}>
  {/* Header */}
  <HeroText tagline="Contact" title="Let's Connect!" />

  {/* Contact Form */}
  <ContactUs
    id="form"
    title="Drop us a message today!"
    subtitle="Have a question about our hosting reviews or want us to benchmark a specific developer tool? Send us a message and we'll get back to you shortly."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Message',
    }}
    disclaimer={{
      label:
        'By submitting this contact form, you agree to the collection of the entered details for contact purposes.',
    }}
    description="We typically respond to inquiries within 24 business hours."
  />

  {/* Contact Info Cards */}
  <Features2
    title="Ways to Reach Us"
    items={[
      {
        title: 'General Inquiries',
        description: 'For general questions about the website, articles, or feedback, email us directly.',
        icon: 'tabler:mail',
      },
      {
        title: 'Email Address',
        description: 'contact@synchrove.com',
        icon: 'tabler:mail-opened',
      },
      {
        title: 'Partnerships',
        description: 'For sponsorship requests or product review inquiries, please include "Partnership" in the subject.',
        icon: 'tabler:briefcase',
      },
    ]}
  />
</Layout>
