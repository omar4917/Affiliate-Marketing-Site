---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title: 'Affiliate Reviews — Honest Reviews & Comparisons for Developers',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Browse Reviews',
        href: '/blog',
        icon: 'tabler:search',
      },
      { text: 'How We Review', href: '#why-trust-us' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-4.0.3&auto=format&fit=crop&w=2072&q=80',
      alt: 'Developer workspace with code on screen',
    }}
  >
    <Fragment slot="title">
      Honest Reviews &<br class="hidden md:inline" /><span class="text-accent dark:text-white"> Developer-First</span> Comparisons
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        We test and compare dev tools, SaaS products, and digital services so you don't have to.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Unbiased product reviews.</span>
      Find the best tools and services for your projects — backed by real testing and hands-on experience.
    </Fragment>
  </Hero>

  <!-- How It Works Section **************** -->

  <Content
    isReversed
    tagline="How It Works"
    title="We Do the Research, You Make the Choice"
    items={[
      {
        title: 'In-Depth Testing',
        description:
          'Every product is tested hands-on with real-world use cases — not just spec sheets and marketing claims.',
      },
      {
        title: 'Side-by-Side Comparisons',
        description:
          'We put competing products head-to-head so you can see exactly how they stack up on price, features, and performance.',
      },
      {
        title: 'No Sponsored Rankings',
        description: 'Our reviews are never pay-to-play. Products earn their ranking through merit, not ad spend.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2015&q=80',
      alt: 'Analytics dashboard on laptop',
    }}
    callToAction={{
      text: 'Browse All Reviews',
      href: '/blog',
      icon: 'tabler:arrow-right',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Reviews You Can Trust</h3>
      We spend hours testing so you can make informed decisions in minutes. Every review includes pricing breakdowns, pros
      & cons, and our honest verdict.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Why Trust Us *************** -->

  <Features
    id="why-trust-us"
    tagline="Why Trust Us"
    title="How We Review Products"
    subtitle="Every review follows a transparent, developer-focused methodology. No sponsored rankings — just honest analysis."
    items={[
      {
        title: 'Hands-On Testing',
        description:
          'We deploy real projects on every platform we review, measuring build times, response latency, and developer experience firsthand.',
        icon: 'tabler:code',
      },
      {
        title: 'Performance Benchmarks',
        description:
          'Standardized tests for TTFB, uptime, CDN coverage, and cold-start times — all with verifiable data.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Transparent Scoring',
        description:
          'Our rating system weighs performance, pricing, ease of use, and support — with the full breakdown shown for every product.',
        icon: 'tabler:star',
      },
      {
        title: 'Updated Regularly',
        description:
          'Hosting platforms change fast. We re-test and update our reviews quarterly to keep recommendations current.',
        icon: 'tabler:refresh',
      },
      {
        title: 'No Pay-to-Play Rankings',
        description:
          'Affiliate commissions never influence our rankings. Products earn their spot through merit, not sponsorship deals.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Community Feedback',
        description:
          'We factor in real user experiences and community sentiment alongside our own testing to give a complete picture.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Latest Posts ******* -->

  <BlogLatestPosts
    title="Latest from the Blog"
    information="Stay up to date with our latest tutorials, comparisons, and industry insights for developers and makers."
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Common questions about our reviews, methodology, and how we make recommendations."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How do you make money from this site?',
        description:
          'We earn commissions through affiliate links when you sign up for a product we recommend. This never influences our rankings — products are ranked purely on merit. We clearly disclose affiliate relationships on every review page.',
      },
      {
        title: 'How do you test products?',
        description:
          'We use every product hands-on for real projects before reviewing it. We evaluate features, pricing, ease of use, documentation, and support quality — then compare it against top alternatives in the same category.',
      },
      {
        title: 'How often are reviews updated?',
        description:
          'We aim to update major comparison pages quarterly and whenever a platform makes significant changes to their pricing, features, or infrastructure. Each review page shows the last-updated date.',
      },
      {
        title: 'Can I suggest a product for review?',
        description:
          'Absolutely! We welcome suggestions from the community. Reach out via our Contact page and let us know which tool or service you would like us to evaluate.',
      },
      {
        title: 'Do you accept sponsored reviews?',
        description:
          'No. All reviews are independently conducted. We may earn affiliate commissions, but no company can pay for a higher ranking or a guaranteed positive review.',
      },
      {
        title: 'Where do I start?',
        description:
          'Head to our Blog to browse the latest reviews and comparisons. Each article includes a clear verdict and recommendation so you can quickly find the right product for your needs.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Explore Reviews',
        href: '/blog',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Find the Right Tools<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> for Your Stack</span>
    </Fragment>

    <Fragment slot="subtitle">
      Stop guessing. Read our in-depth comparisons and choose the best tools and services for your projects.
    </Fragment>
  </CallToAction>
</Layout>
