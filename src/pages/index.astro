---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title: 'Football Gear & Tactics — In-Depth Reviews & Analysis',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Browse Articles',
        href: '/blog',
        icon: 'tabler:search',
      },
      { text: 'How We Review', href: '#why-trust-us' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?auto=format&fit=crop&w=1650&q=80',
      alt: 'Football field stadium',
    }}
  >
    <Fragment slot="title">
      In-Depth Reviews &<br class="hidden md:inline" /><span class="text-accent dark:text-white"> Football-First</span> Analysis
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        We test and compare football boots, training gear, and break down professional tactics so you can elevate your game.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Unbiased football reviews.</span>
      Find the best gear and training strategies — backed by real on-pitch testing.
    </Fragment>
  </Hero>

  <!-- How It Works Section **************** -->

  <Content
    isReversed
    tagline="How It Works"
    title="We Do the Pitch Work, You Make the Choice"
    items={[
      {
        title: 'On-Pitch Testing',
        description:
          'Every pair of boots and piece of training gear is tested hands-on in real training sessions and matches.',
      },
      {
        title: 'Side-by-Side Comparisons',
        description:
          'We put competing gear head-to-head so you can see exactly how they compare on durability, weight, comfort, and price.',
      },
      {
        title: 'Unbiased Reviews',
        description: 'Our reviews are never sponsored. Products earn their rankings purely through performance.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1518063319789-7217e6706b04?auto=format&fit=crop&w=1650&q=80',
      alt: 'Football boot on turf field',
    }}
    callToAction={{
      text: 'Browse All Articles',
      href: '/blog',
      icon: 'tabler:arrow-right',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Reviews You Can Trust</h3>
      We spend hours testing on the field so you can make informed decisions in minutes. Every review includes pros & cons, fit guides, and our honest verdict.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Why Trust Us *************** -->

  <Features
    id="why-trust-us"
    tagline="Why Trust Us"
    title="How We Review Gear & Tactics"
    subtitle="Every article follows a transparent, athlete-focused methodology. No sponsored rankings — just honest analysis."
    items={[
      {
        title: 'On-Pitch Testing',
        description:
          'We wear every boot and use every accessory in real sessions, measuring durability, traction, comfort, and performance.',
        icon: 'tabler:run',
      },
      {
        title: 'Performance Benchmarks',
        description:
          'Standardized tests for stud pressure, weight, lock-down, and agility response.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Transparent Scoring',
        description:
          'Our rating system weighs comfort, durability, price, and technology — showing the full breakdown for every item.',
        icon: 'tabler:star',
      },
      {
        title: 'Season-by-Season Updates',
        description:
          'Football boots and gear models change fast. We re-test and update our reviews to keep recommendations current.',
        icon: 'tabler:refresh',
      },
      {
        title: 'No Sponsored Rankings',
        description:
          'Affiliate commissions never influence our rankings. Products earn their spot through merit, not sponsorship deals.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Player Feedback',
        description:
          'We factor in opinions from players across different skill levels and pitch roles to provide a complete picture.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Latest Posts ******* -->

  <BlogLatestPosts
    title="Latest from the Blog"
    information="Stay up to date with our latest tactics breakdowns, boot reviews, and coaching resources."
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Common questions about our gear reviews, tactical analysis, and how we test."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How do you test football gear?',
        description:
          'We wear and test boots on different ground types (FG, SG, AG, TF) to measure traction, fit, durability, and comfort under match conditions.',
      },
      {
        title: 'Are your tactical analyses based on real data?',
        description:
          'Yes. We use match video footage, passing networks, heatmaps, and statistical metrics to break down professional team systems and strategies.',
      },
      {
        title: 'How often are reviews updated?',
        description:
          'We update our recommendations quarterly and when major brands launch new boot silos or update existing models.',
      },
      {
        title: 'How do you monetize this site?',
        description:
          'We earn affiliate commissions when you purchase gear through our links. This comes at no extra cost to you and helps support our testing efforts.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Explore Blog',
        href: '/blog',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Elevate Your Game<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> Today</span>
    </Fragment>

    <Fragment slot="subtitle">
      Stop guessing. Read our in-depth guides and choose the best gear and tactical setups for your team.
    </Fragment>
  </CallToAction>
</Layout>
